# Copy this file to .env when you prefer environment-based defaults.
# Runtime changes made in the web UI are encrypted and stored in data/code_navi_mvp.db.

# --- LLM API (OpenAI-compatible) ---
# DeepSeek:       LLM_BASE_URL=https://api.deepseek.com/v1      LLM_MODEL=deepseek-chat
# SiliconFlow:    LLM_BASE_URL=https://api.siliconflow.cn/v1    LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# Ollama (local): LLM_BASE_URL=http://localhost:11434/v1        LLM_MODEL=qwen2.5:7b
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Optional proxy inherited by paper-search subprocesses.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Generated automatically on the first persistent API-key save.
# Do not commit the real value and do not lose it, or the stored key cannot be decrypted.
CODE_NAVI_CONFIG_KEY=
